# Server port (default: 3001)
PORT=3001

# Environment (development | production)
# In production: serves built client, restricts CORS, uses JSON logging
NODE_ENV=development

# Comma-separated allowed CORS origins in production
# If unset in production, only same-origin requests are allowed
# CORS_ORIGINS=https://bullem.fly.dev,https://bullem.com

# Redis connection URL (optional)
# Enables: Socket.io multi-instance pub/sub, session persistence (rooms survive restarts)
# REDIS_URL=redis://localhost:6379

# PostgreSQL connection string (optional)
# Enables: user accounts, persistent stats, game history
# DATABASE_URL=postgresql://user:password@localhost:5432/bullem

# JWT signing secret (required when DATABASE_URL is set)
# Generate a strong random string for production
# SESSION_SECRET=your-secret-here

# Sentry DSN for error tracking (optional)
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Log level: trace | debug | info | warn | error | fatal (default: info)
# LOG_LEVEL=info
