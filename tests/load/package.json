{
  "name": "@bull-em/load-tests",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "tsx src/runner.ts",
    "scenario:rooms": "tsx src/runner.ts --scenario room-throughput",
    "scenario:games": "tsx src/runner.ts --scenario full-game",
